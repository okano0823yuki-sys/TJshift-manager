// 日本の祝日を判定
function isJapaneseHoliday(year, month, day) {
    // 月は0始まりではなく1始まり
    const holidays = {
        '1-1': '元日',
        '1-2': '振替休日', // 2024年以降の例
        '2-11': '建国記念の日',
        '2-23': '天皇誕生日',
        '3-20': '春分の日', // 年によって変動
        '3-21': '春分の日', // 年によって変動
        '4-29': '昭和の日',
        '5-3': '憲法記念日',
        '5-4': 'みどりの日',
        '5-5': 'こどもの日',
        '7-15': '海の日', // 第3月曜日（簡易版）
        '8-11': '山の日',
        '9-16': '敬老の日', // 第3月曜日（簡易版）
        '9-22': '秋分の日', // 年によって変動
        '9-23': '秋分の日', // 年によって変動
        '10-14': 'スポーツの日', // 第2月曜日（簡易版）
        '11-3': '文化の日',
        '11-23': '勤労感謝の日'
    };
    
    const key = `${month}-${day}`;
    return holidays[key] !== undefined;
}

// カレンダーセレクターを描画
function renderCalendarSelector() {
    const year = currentCalendarMonth.getFullYear();
    const month = currentCalendarMonth.getMonth();
    
    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const prevLastDay = new Date(year, month, 0);
    
    const firstDayOfWeek = firstDay.getDay();
    const lastDate = lastDay.getDate();
    const prevLastDate = prevLastDay.getDate();
    
    const today = new Date();
    const todayStr = today.toISOString().split('T')[0];
    
    // 既存のシフトを取得
    const shifts = getShifts();
    let staffName = '';
    
    if (isAdminMode) {
        const staffNameSelect = document.getElementById('staffName');
        staffName = staffNameSelect ? staffNameSelect.value : '';
    } else {
        staffName = currentUser ? currentUser.name : '';
    }
    
    const shiftDates = new Set(
        shifts
            .filter(s => s.staffName === staffName)
            .map(s => s.date)
    );
    
    let html = `
        <div class="calendar-header">
            <button type="button" onclick="changeCalendarMonth(-1)">◀</button>
            <h3>${year}年 ${month + 1}月</h3>
            <button type="button" onclick="changeCalendarMonth(1)">▶</button>
        </div>
        <div class="calendar-weekdays">
            <div class="calendar-weekday">日</div>
            <div class="calendar-weekday">月</div>
            <div class="calendar-weekday">火</div>
            <div class="calendar-weekday">水</div>
            <div class="calendar-weekday">木</div>
            <div class="calendar-weekday">金</div>
            <div class="calendar-weekday">土</div>
        </div>
        <div class="calendar-days">
    `;
    
    // 前月の日付
    for (let i = firstDayOfWeek - 1; i >= 0; i--) {
        const day = prevLastDate - i;
        html += `<div class="calendar-day-cell other-month">${day}</div>`;
    }
    
    // 当月の日付
    for (let day = 1; day <= lastDate; day++) {
        const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
        const currentDate = new Date(year, month, day);
        const dayOfWeek = currentDate.getDay(); // 0=日曜, 6=土曜
        const isToday = dateStr === todayStr;
        const isSelected = selectedDates.includes(dateStr);
        const hasShift = shiftDates.has(dateStr);
        const isHoliday = isJapaneseHoliday(year, month + 1, day);
        
        const classes = ['calendar-day-cell'];
        if (isToday) classes.push('today');
        if (isSelected) classes.push('selected');
        if (hasShift) classes.push('has-shift');
        if (dayOfWeek === 0) classes.push('sunday'); // 日曜日
        if (dayOfWeek === 6) classes.push('saturday'); // 土曜日
        if (isHoliday) classes.push('holiday'); // 祝日
        
        html += `<div class="${classes.join(' ')}" onclick="toggleDateSelection('${dateStr}')">${day}</div>`;
    }
    
    // 次月の日付
    const remainingCells = 42 - (firstDayOfWeek + lastDate);
    for (let day = 1; day <= remainingCells; day++) {
        html += `<div class="calendar-day-cell other-month">${day}</div>`;
    }
    
    html += '</div>';
    
    document.getElementById('calendarSelector').innerHTML = html;
    updateSelectedDatesDisplay();
}

// カレンダーの月を変更
function changeCalendarMonth(delta) {
    currentCalendarMonth.setMonth(currentCalendarMonth.getMonth() + delta);
    renderCalendarSelector();
}

// 日付選択をトグル
function toggleDateSelection(dateStr) {
    const index = selectedDates.indexOf(dateStr);
    if (index > -1) {
        // 既に選択されている場合は選択解除
        selectedDates.splice(index, 1);
    } else {
        // 新規選択の場合、重複チェック
        const shifts = getShifts();
        let staffName;
        
        // スタッフ名を取得
        if (isAdminMode) {
            const staffNameSelect = document.getElementById('staffName');
            staffName = staffNameSelect ? staffNameSelect.value : '';
        } else {
            staffName = currentUser ? currentUser.name : '';
        }
        
        if (!staffName) {
            // スタッフ名が未選択の場合は、重複チェックをスキップして選択を許可
            selectedDates.push(dateStr);
            renderCalendarSelector();
            return;
        }
        
        // 同じスタッフが同じ日に既にシフト登録しているかチェック
        const isDuplicate = shifts.some(shift => 
            shift.staffName === staffName && shift.date === dateStr
        );
        
        if (isDuplicate) {
            alert(`${dateStr} は既に登録されています。\n重複登録はできません。`);
            return;
        }
        
        selectedDates.push(dateStr);
    }
    renderCalendarSelector();
}

// 選択された日付の表示を更新
function updateSelectedDatesDisplay() {
    const display = document.getElementById('selectedDatesDisplay');
    if (selectedDates.length === 0) {
        display.textContent = '選択された日付: なし';
    } else {
        const sortedDates = [...selectedDates].sort();
        display.textContent = `選択された日付: ${sortedDates.map(d => {
            const date = new Date(d);
            return `${date.getMonth() + 1}/${date.getDate()}`;
        }).join(', ')}`;
    }
}

// シフト編集
function editShift(id) {
    const shifts = getShifts();
    const shift = shifts.find(s => s.id === id);
    
    if (!shift) return;
    
    if (isAdminMode) {
        document.getElementById('staffName').value = shift.staffName;
    }
    
    // 単一日付を選択
    selectedDates = [shift.date];
    renderCalendarSelector();
    
    document.getElementById('earlyLeave').checked = shift.earlyLeave || false;
    document.getElementById('lateStart').checked = shift.lateStart || false;
    
    if (isAdminMode) {
        document.getElementById('hourlyWage').value = shift.hourlyWage || '';
    }
    
    // メモからオプションを除去
    let cleanMemo = shift.memo || '';
    if (cleanMemo.includes('早上がり') || cleanMemo.includes('遅出')) {
        const parts = cleanMemo.split(' / ');
        cleanMemo = parts.length > 1 ? parts[1] : '';
    }
    document.getElementById('memo').value = cleanMemo;
    
    document.getElementById('editingId').value = shift.id;
    document.getElementById('submitBtn').textContent = '更新';
    document.getElementById('cancelBtn').style.display = 'inline-block';
    
    // フォームまでスクロール
    document.querySelector('.input-section').scrollIntoView({ behavior: 'smooth' });
}

// 編集キャンセル
function cancelEdit() {
    document.getElementById('shiftForm').reset();
    document.getElementById('editingId').value = '';
    document.getElementById('submitBtn').textContent = '登録';
    document.getElementById('cancelBtn').style.display = 'none';
    selectedDates = [];
    renderCalendarSelector();
}

// シフト削除
function deleteShift(id) {
    const shifts = getShifts();
    const shift = shifts.find(s => s.id === id);
    
    if (!shift) {
        alert('シフトが見つかりません');
        return;
    }
    
    // スタッフモードの場合、自分のシフトのみ削除可能
    if (!isAdminMode && currentUser && shift.staffName !== currentUser.name) {
        alert('自分のシフトのみ削除できます');
        return;
    }
    
    if (!confirm('このシフトを削除しますか？')) {
        return;
    }
    
    const updatedShifts = shifts.filter(s => s.id !== id);
    saveShifts(updatedShifts);
    
    updateStaffList();
    displayShifts();
    updateStats();
    displayTodayShift(); // 本日のシフトを更新
    renderCalendarSelector(); // カレンダーを更新
    alert('シフトを削除しました');
}

// シフト一覧を表示
function displayShifts(filterMonth = null, filterStaff = null) {
    const shifts = getShifts();
    const shiftList = document.getElementById('shiftList');
    
    let filteredShifts = shifts;
    
    // スタッフモードの場合は自分のシフトのみ表示
    if (!isAdminMode && currentUser) {
        filteredShifts = filteredShifts.filter(shift => shift.staffName === currentUser.name);
    }
    
    if (filterMonth) {
        filteredShifts = filteredShifts.filter(shift => shift.date.startsWith(filterMonth));
    }
    
    if (filterStaff) {
        filteredShifts = filteredShifts.filter(shift => shift.staffName === filterStaff);
    }
    
    // 日付の新しい順にソート
    filteredShifts.sort((a, b) => {
        const dateCompare = new Date(b.date) - new Date(a.date);
        if (dateCompare !== 0) return dateCompare;
        return a.startTime ? a.startTime.localeCompare(b.startTime) : 0;
    });
    
    if (filteredShifts.length === 0) {
        shiftList.innerHTML = '<div class="no-shifts">シフトが登録されていません</div>';
        return;
    }
    
    // 管理者モードの場合は日付ごとにグループ化
    if (isAdminMode) {
        const shiftsByDate = {};
        filteredShifts.forEach(shift => {
            if (!shiftsByDate[shift.date]) {
                shiftsByDate[shift.date] = [];
            }
            shiftsByDate[shift.date].push(shift);
        });
        
        const sortedDates = Object.keys(shiftsByDate).sort((a, b) => new Date(b) - new Date(a));
        
        shiftList.innerHTML = sortedDates.map(date => {
            const dayShifts = shiftsByDate[date];
            return `
                <div class="shift-group">
                    <div class="shift-group-header">${formatDate(date)}</div>
                    <div class="shift-group-items">
                        ${dayShifts.map(shift => `
                            <div class="shift-group-item">
                                <div class="shift-group-staff">👤 ${shift.staffName}</div>
                                <div class="shift-group-details">
                                    ${shift.memo ? `📝 ${shift.memo}` : ''}
                                    ${shift.hourlyWage > 0 ? `<br>💰 時給 ¥${shift.hourlyWage.toLocaleString()}` : ''}
                                </div>
                                <div class="shift-actions" style="margin-top: 8px;">
                                    <button onclick="editShift(${shift.id})" class="btn btn-edit btn-small">編集</button>
                                    <button onclick="deleteShift(${shift.id})" class="btn btn-danger btn-small">削除</button>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                </div>
            `;
        }).join('');
    } else {
        // スタッフモードは従来通り
        shiftList.innerHTML = filteredShifts.map(shift => `
            <div class="shift-item">
                <div class="shift-header">
                    <div>
                        <div class="shift-date">${formatDate(shift.date)}</div>
                    </div>
                </div>
                <div class="shift-details">
                    ${shift.memo ? `<div>📝 ${shift.memo}</div>` : ''}
                </div>
                <div class="shift-actions" style="margin-top: 8px;">
                    <button onclick="deleteShift(${shift.id})" class="btn btn-danger btn-small">取り消し</button>
                </div>
            </div>
        `).join('');
    }
}

// カレンダー表示
function displayCalendarView() {
    const shifts = getShifts();
    const calendarView = document.getElementById('calendarView');
    const settings = getSettings();
    
    const filterMonth = document.getElementById('filterMonth').value;
    const filterStaff = document.getElementById('filterStaff').value;
    
    let filteredShifts = shifts;
    
    // スタッフモードの場合は自分のシフトのみ表示
    if (!isAdminMode && currentUser) {
        filteredShifts = filteredShifts.filter(shift => shift.staffName === currentUser.name);
    }
    
    if (filterMonth) {
        filteredShifts = filteredShifts.filter(shift => shift.date.startsWith(filterMonth));
    }
    
    if (filterStaff) {
        filteredShifts = filteredShifts.filter(shift => shift.staffName === filterStaff);
    }
    
    // 日付ごとにグループ化
    const shiftsByDate = {};
    filteredShifts.forEach(shift => {
        if (!shiftsByDate[shift.date]) {
            shiftsByDate[shift.date] = [];
        }
        shiftsByDate[shift.date].push(shift);
    });
    
    // 日付順にソート
    const sortedDates = Object.keys(shiftsByDate).sort((a, b) => new Date(b) - new Date(a));
    
    if (sortedDates.length === 0) {
        calendarView.innerHTML = '<div class="no-shifts">シフトが登録されていません</div>';
        return;
    }
    
    calendarView.innerHTML = sortedDates.map(date => {
        const dayShifts = shiftsByDate[date].sort((a, b) => a.startTime ? a.startTime.localeCompare(b.startTime) : 0);
        
        return `
            <div class="calendar-day">
                <div class="calendar-day-header">
                    ${formatDate(date)}
                    <span class="business-hours">営業時間: ${settings.openTime} - ${settings.closeTime}</span>
                </div>
                ${dayShifts.map(shift => {
                    const hasConflict = checkTimeConflict(shift, dayShifts);
                    return `
                        <div class="calendar-shift ${hasConflict ? 'time-conflict' : ''}">
                            ${isAdminMode ? `<span class="calendar-shift-name">${shift.staffName}</span>` : ''}
                            ${shift.memo ? `<span class="calendar-shift-time">${shift.memo}</span>` : ''}
                            ${hasConflict ? ' ⚠️ 重複' : ''}
                        </div>
                    `;
                }).join('')}
            </div>
        `;
    }).join('');
}

// 時間の重複チェック（同じスタッフが同じ日に複数シフト）
function checkTimeConflict(shift, dayShifts) {
    return dayShifts.some(other => {
        if (other.id === shift.id) return false;
        return other.staffName === shift.staffName;
    });
}

// 統計情報を更新
function updateStats() {
    const shifts = getShifts();
    const currentMonth = new Date().toISOString().slice(0, 7);
    
    let monthlyShifts = shifts.filter(shift => shift.date.startsWith(currentMonth));
    
    // スタッフモードの場合は自分のシフトのみ集計
    if (!isAdminMode && currentUser) {
        monthlyShifts = monthlyShifts.filter(shift => shift.staffName === currentUser.name);
    } else if (isAdminMode) {
        // 管理者モードでフィルターが選択されている場合
        const filterStaff = document.getElementById('filterStaff').value;
        if (filterStaff) {
            monthlyShifts = monthlyShifts.filter(shift => shift.staffName === filterStaff);
        }
    }
    
    const totalDays = monthlyShifts.length;
    const totalSalary = monthlyShifts.reduce((sum, shift) => sum + (shift.hourlyWage || 0), 0);
    
    document.getElementById('monthlyHours').textContent = `${totalDays}日`;
    document.getElementById('monthlySalary').textContent = `¥${totalSalary.toLocaleString()}`;
}

// フィルター適用
function applyFilters() {
    const filterMonth = document.getElementById('filterMonth').value;
    const filterStaff = document.getElementById('filterStaff').value;
    
    if (currentView === 'calendar') {
        displayCalendarView();
    } else {
        displayShifts(filterMonth, filterStaff);
    }
    updateStats();
}

// フィルタークリア
function clearFilter() {
    document.getElementById('filterMonth').value = new Date().toISOString().slice(0, 7);
    document.getElementById('filterStaff').value = '';
    applyFilters();
}

// メッセージ機能

// メッセージデータを取得
function getMessages() {
    const data = localStorage.getItem(MESSAGE_KEY);
    return data ? JSON.parse(data) : [];
}

// メッセージデータを保存
function saveMessages(messages) {
    localStorage.setItem(MESSAGE_KEY, JSON.stringify(messages));
}

// 削除済みメッセージIDを取得
function getDeletedMessageIds() {
    if (!currentUser) return [];
    const key = `deletedMessages_${currentUser.name}`;
    const data = localStorage.getItem(key);
    return data ? JSON.parse(data) : [];
}

// 削除済みメッセージIDを保存
function saveDeletedMessageIds(ids) {
    if (!currentUser) return;
    const key = `deletedMessages_${currentUser.name}`;
    localStorage.setItem(key, JSON.stringify(ids));
}

// メッセージを削除（自分の表示から消すだけ）
function deleteMessage(messageId) {
    if (!currentUser) return;
    
    if (!confirm('このメッセージを削除しますか？')) {
        return;
    }
    
    const deletedIds = getDeletedMessageIds();
    if (!deletedIds.includes(messageId)) {
        deletedIds.push(messageId);
        saveDeletedMessageIds(deletedIds);
    }
    
    displayMessages();
    alert('メッセージを削除しました');
}

// 最終既読時刻を保存
function saveLastReadTime() {
    if (!currentUser) return;
    const key = `${LAST_READ_KEY}_${currentUser.name}`;
    localStorage.setItem(key, new Date().toISOString());
    lastReadMessageTime = new Date().toISOString();
}

// 最終既読時刻を読み込み
function loadLastReadTime() {
    if (!currentUser) return;
    const key = `${LAST_READ_KEY}_${currentUser.name}`;
    lastReadMessageTime = localStorage.getItem(key);
}

// 未読メッセージ数を取得
function getUnreadMessageCount() {
    if (!currentUser) return 0;
    
    const messages = getMessages();
    const filteredMessages = messages.filter(msg => {
        if (msg.from === currentUser.name) return false; // 自分が送信したメッセージは除外
        if (msg.to === '全員') return true;
        if (msg.to === currentUser.name) return true;
        if (isAdminMode && msg.to === '店長') return true;
        return false;
    });
    
    if (!lastReadMessageTime) return filteredMessages.length;
    
    const unreadMessages = filteredMessages.filter(msg => 
        new Date(msg.timestamp) > new Date(lastReadMessageTime)
    );
    
    return unreadMessages.length;
}

// メッセージバッジを更新
function updateMessageBadge() {
    const badge = document.getElementById('messageBadge');
    if (!badge) return;
    
    const unreadCount = getUnreadMessageCount();
    
    if (unreadCount > 0) {
        badge.textContent = unreadCount;
        badge.style.display = 'inline-block';
    } else {
        badge.style.display = 'none';
    }
}

