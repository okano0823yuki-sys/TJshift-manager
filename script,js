// スタッフデータを取得
function getStaffData() {
    const data = localStorage.getItem(STAFF_KEY);
    return data ? JSON.parse(data) : [];
}

// スタッフデータを保存
function saveStaffData(staffData) {
    localStorage.setItem(STAFF_KEY, JSON.stringify(staffData));
}

// スタッフを登録
function registerStaff(name, password) {
    const staffData = getStaffData();
    
    // 既に存在するか確認
    if (staffData.find(s => s.name === name)) {
        return false;
    }
    
    staffData.push({ name, password });
    saveStaffData(staffData);
    return true;
}

// ログイン処理
function login(name, password, asAdmin) {
    if (asAdmin) {
        if (password === ADMIN_PASSWORD) {
            currentUser = { name: '管理者', isAdmin: true };
            isAdminMode = true;
            return true;
        }
        return false;
    } else {
        const staffData = getStaffData();
        const staff = staffData.find(s => s.name === name && s.password === password);
        if (staff) {
            currentUser = { name: staff.name, isAdmin: false };
            isAdminMode = false;
            return true;
        }
        return false;
    }
}

