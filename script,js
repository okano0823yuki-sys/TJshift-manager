// DOMContentLoaded後にイベントリスナーを設定
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeApp);
} else {
    initializeApp();
}

function initializeApp() {
    initLoginScreen();
    
    // ログインフォーム送信
    document.getElementById('loginForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const name = document.getElementById('loginName').value;
        const password = document.getElementById('loginPassword').value;
        const asAdmin = document.getElementById('loginAsAdmin').checked;
        
        if (asAdmin || name === '店長') {
            if (login('管理者', password, true)) {
                document.getElementById('loginScreen').style.display = 'none';
                document.getElementById('mainScreen').style.display = 'block';
                document.getElementById('currentUser').textContent = '👤 店長（管理者）';
                updateAdminUI();
                initMainScreen();
            } else {
                alert('管理者パスワードが正しくありません');
            }
        } else {
            if (!name) {
                alert('名前を選択してください');
                return;
            }
            
            if (login(name, password, false)) {
                document.getElementById('loginScreen').style.display = 'none';
                document.getElementById('mainScreen').style.display = 'block';
                document.getElementById('currentUser').textContent = `👤 ${name}`;
                updateAdminUI();
                initMainScreen();
            } else {
                alert('名前またはパスワードが正しくありません');
            }
        }
    });

    // スタッフ登録フォーム
    document.getElementById('staffForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const name = document.getElementById('newStaffName').value.trim();
        const password = document.getElementById('newStaffPassword').value;
        
        if (!name || !password) {
            alert('名前とパスワードを入力してください');
            return;
        }
        
        if (registerStaff(name, password)) {
            alert('スタッフを登録しました');
            document.getElementById('newStaffName').value = '';
            document.getElementById('newStaffPassword').value = '';
            displayStaffList();
            initLoginScreen();
            updateStaffNameSelect();
        } else {
            alert('このスタッフ名は既に登録されています');
        }
    });

    // シフト登録フォーム
    document.getElementById('shiftForm').addEventListener('submit', handleShiftSubmit);
    
    // メッセージフォーム
    document.getElementById('messageForm').addEventListener('submit', handleMessageSubmit);
}

function handleShiftSubmit(e) {
    e.preventDefault();
    
    console.log('シフト登録開始');
    console.log('isAdminMode:', isAdminMode);
    console.log('currentUser:', currentUser);
    
    let staffName;
    if (isAdminMode) {
        staffName = document.getElementById('staffName').value;
        if (!staffName) {
            alert('スタッフ名を選択してください');
            return;
        }
    } else {
        if (!currentUser) {
            alert('ログインしてください');
            return;
        }
        staffName = currentUser.name;
    }
    
    console.log('staffName:', staffName);
    console.log('selectedDates:', selectedDates);
    
    if (selectedDates.length === 0) {
        alert('日付を選択してください');
        return;
    }
    
    const earlyLeave = document.getElementById('earlyLeave').checked;
    const lateStart = document.getElementById('lateStart').checked;
    const workArea = document.getElementById('workArea').value;
    const hourlyWage = parseInt(document.getElementById('hourlyWage').value) || 0;
    const memo = document.getElementById('memo').value;
    const editingId = document.getElementById('editingId').value;
    
    console.log('earlyLeave:', earlyLeave, 'lateStart:', lateStart, 'workArea:', workArea);
    
    // オプションをメモに追加
    let fullMemo = memo;
    const options = [];
    if (earlyLeave) options.push('早上がり');
    if (lateStart) options.push('遅出');
    if (options.length > 0) {
        fullMemo = options.join(', ') + (memo ? ' / ' + memo : '');
    }
    
    console.log('fullMemo:', fullMemo);
    
    const shifts = getShifts();
    
    if (editingId) {
        // 編集モード（単一日付のみ）
        const index = shifts.findIndex(s => s.id === parseInt(editingId));
        if (index !== -1) {
            shifts[index] = {
                ...shifts[index],
                staffName,
                date: selectedDates[0],
                earlyLeave,
                lateStart,
                workArea,
                hourlyWage,
                memo: fullMemo
            };
        }
    } else {
        // 新規登録（複数日付対応）
        selectedDates.forEach(date => {
            const shift = {
                id: Date.now() + Math.random(),
                staffName,
                date,
                earlyLeave,
                lateStart,
                workArea,
                hourlyWage,
                memo: fullMemo
            };
            console.log('新規シフト作成:', shift);
            shifts.push(shift);
        });
    }
    
    console.log('保存前のシフト数:', shifts.length);
    saveShifts(shifts);
    console.log('シフト保存完了');
    
    // フォームをリセット
    document.getElementById('shiftForm').reset();
    document.getElementById('editingId').value = '';
    document.getElementById('submitBtn').textContent = '登録';
    document.getElementById('cancelBtn').style.display = 'none';
    selectedDates = [];
    
    updateStaffList();
    displayShifts();
    updateStats();
    renderCalendarSelector();
    displayTodayShift(); // 本日のシフトを更新
    
    alert(editingId ? 'シフトを更新しました！' : 'シフトを登録しました！');
}

