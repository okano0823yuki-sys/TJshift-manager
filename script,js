// メッセージ送信
function handleMessageSubmit(e) {
    e.preventDefault();
    
    if (!currentUser) {
        alert('ログインしてください');
        return;
    }
    
    const to = document.getElementById('messageTo').value;
    const text = document.getElementById('messageText').value.trim();
    
    if (!to || !text) {
        alert('送信先とメッセージを入力してください');
        return;
    }
    
    const messages = getMessages();
    const message = {
        id: Date.now(),
        from: currentUser.name,
        to: to,
        text: text,
        timestamp: new Date().toISOString(),
        acknowledged: false,
        acknowledgedBy: []
    };
    
    messages.push(message);
    saveMessages(messages);
    
    document.getElementById('messageText').value = '';
    document.getElementById('messageTo').value = '';
    
    displayMessages();
    updateMessageBadge();
    alert('メッセージを送信しました！');
}

// メッセージに承知しましたを追加
function acknowledgeMessage(messageId) {
    if (!currentUser) return;
    
    const messages = getMessages();
    const message = messages.find(m => m.id === messageId);
    
    if (!message) return;
    
    // 既に承知済みかチェック
    if (!message.acknowledgedBy) {
        message.acknowledgedBy = [];
    }
    
    if (message.acknowledgedBy.includes(currentUser.name)) {
        alert('既に承知済みです');
        return;
    }
    
    message.acknowledgedBy.push(currentUser.name);
    message.acknowledged = true;
    
    saveMessages(messages);
    displayMessages();
    alert('承知しました！');
}

// メッセージ表示
function displayMessages() {
    const messages = getMessages();
    const messageList = document.getElementById('messageList');
    
    if (!currentUser) return;
    
    // 削除済みメッセージIDを取得
    const deletedIds = getDeletedMessageIds();
    
    // 自分宛のメッセージまたは自分が送信したメッセージをフィルター
    let filteredMessages = messages.filter(msg => {
        // 削除済みメッセージを除外
        if (deletedIds.includes(msg.id)) return false;
        
        if (msg.to === '全員') return true;
        if (msg.to === currentUser.name) return true;
        if (msg.from === currentUser.name) return true;
        if (isAdminMode && msg.to === '店長') return true;
        return false;
    });
    
    // 新しい順にソート
    filteredMessages.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
    
    if (filteredMessages.length === 0) {
        messageList.innerHTML = '<div class="no-messages">メッセージがありません</div>';
        return;
    }
    
    messageList.innerHTML = filteredMessages.map(msg => {
        const date = new Date(msg.timestamp);
        const timeStr = `${date.getMonth() + 1}/${date.getDate()} ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
        
        const isReceived = msg.from !== currentUser.name;
        const hasAcknowledged = msg.acknowledgedBy && msg.acknowledgedBy.includes(currentUser.name);
        const acknowledgedList = msg.acknowledgedBy && msg.acknowledgedBy.length > 0 
            ? msg.acknowledgedBy.join(', ') 
            : '';
        
        return `
            <div class="message-item ${msg.acknowledged ? 'message-acknowledged' : ''}">
                <div class="message-header">
                    <div>
                        <span class="message-from">${msg.from}</span>
                        <span class="message-to">→ ${msg.to}</span>
                    </div>
                    <div>
                        <span class="message-time">${timeStr}</span>
                        <button onclick="deleteMessage(${msg.id})" class="btn-delete-message" title="削除">🗑️</button>
                    </div>
                </div>
                <div class="message-text">${msg.text}</div>
                ${isReceived && !hasAcknowledged ? `
                    <div class="message-actions">
                        <button onclick="acknowledgeMessage(${msg.id})" class="btn-acknowledge">
                            ✓ 承知しました
                        </button>
                    </div>
                ` : ''}
                ${hasAcknowledged ? `
                    <div class="acknowledged-text">✓ 承知済み</div>
                ` : ''}
                ${acknowledgedList && msg.from === currentUser.name ? `
                    <div class="acknowledged-text">✓ 承知: ${acknowledgedList}</div>
                ` : ''}
            </div>
        `;
    }).join('');
}


