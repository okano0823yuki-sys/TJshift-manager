// 30分単位の時間オプションを生成
function generateTimeOptions(startHour = 0, endHour = 24, includeEnd = true) {
    const options = [];
    for (let h = startHour; h <= endHour; h++) {
        if (h > endHour) break;
        
        const maxMin = (h === endHour && !includeEnd) ? 0 : 60;
        
        for (let m = 0; m < maxMin; m += 30) {
            const hour = String(h).padStart(2, '0');
            const min = String(m).padStart(2, '0');
            options.push(`${hour}:${min}`);
        }
    }
    return options;
}

// 時間選択を初期化
function initTimeSelects() {
    const settings = getSettings();
    const openTime = settings.openTime;
    const closeTime = settings.closeTime;
    
    // 営業時間設定用（0:00から24:00まで）
    const openSelect = document.getElementById('openTime');
    const closeSelect = document.getElementById('closeTime');
    
    if (!openSelect || !closeSelect) return;
    
    const allTimes = generateTimeOptions(0, 24, true);
    
    openSelect.innerHTML = allTimes.map(time => 
        `<option value="${time}" ${time === openTime ? 'selected' : ''}>${time}</option>`
    ).join('');
    
    closeSelect.innerHTML = allTimes.map(time => 
        `<option value="${time}" ${time === closeTime ? 'selected' : ''}>${time}</option>`
    ).join('');
    
    // シフト入力用（営業時間に基づく）
    const startSelect = document.getElementById('startTime');
    const endSelect = document.getElementById('endTime');
    
    if (!startSelect || !endSelect) return;
    
    const [openH] = openTime.split(':').map(Number);
    let [closeH] = closeTime.split(':').map(Number);
    
    // 閉店時間が24:00の場合
    if (closeH === 24 || closeTime === '24:00') {
        closeH = 24;
    }
    
    // 営業時間の範囲で時間を生成（閉店時間+1時間まで）
    const shiftTimes = generateTimeOptions(openH, Math.min(closeH + 1, 24), true);
    
    startSelect.innerHTML = shiftTimes.map(time => 
        `<option value="${time}">${time}</option>`
    ).join('');
    
    endSelect.innerHTML = shiftTimes.map(time => 
        `<option value="${time}">${time}</option>`
    ).join('');
}

// 勤務時間を計算（時間単位）
function calculateHours(startTime, endTime) {
    const [startHour, startMin] = startTime.split(':').map(Number);
    let [endHour, endMin] = endTime.split(':').map(Number);
    
    // 24:00の場合
    if (endHour === 24) {
        endHour = 0;
        endMin = 0;
    }
    
    const startMinutes = startHour * 60 + startMin;
    let endMinutes = endHour * 60 + endMin;
    
    // 日をまたぐ場合
    if (endMinutes <= startMinutes) {
        endMinutes += 24 * 60;
    }
    
    return (endMinutes - startMinutes) / 60;
}

// 給与を計算
function calculateWage(hours, hourlyWage) {
    return Math.floor(hours * hourlyWage);
}

// 日付をフォーマット
function formatDate(dateString) {
    const date = new Date(dateString);
    const days = ['日', '月', '火', '水', '木', '金', '土'];
    const year = date.getFullYear();
    const month = date.getMonth() + 1;
    const day = date.getDate();
    const dayOfWeek = days[date.getDay()];
    
    return `${year}年${month}月${day}日（${dayOfWeek}）`;
}

